datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id             BigInt   @id @default(autoincrement())
  ticker         String   @unique
  cik            String   @unique
  companyName    String   @map("company_name")
  sic            String?  @db.Text
  fiscalYearEnd  String?  @map("fiscal_year_end")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  filings        Filing[]

  @@map("companies")
}

model Filing {
  id               BigInt          @id @default(autoincrement())
  companyId        BigInt          @map("company_id")
  accessionNumber  String          @unique @map("accession_number")
  filingDate       DateTime        @map("filing_date")
  reportDate       DateTime?       @map("report_date")
  form             String
  primaryDocument  String          @map("primary_document")
  description      String
  secUrl           String          @map("sec_url")
  rawTextHash      String?         @map("raw_text_hash")
  createdAt        DateTime        @default(now()) @map("created_at")
  company          Company         @relation(fields: [companyId], references: [id])
  document         FilingDocument?
  events           FilingEvent[]

  @@index([companyId, filingDate(sort: Desc)])
  @@map("filings")
}

model FilingDocument {
  id          BigInt   @id @default(autoincrement())
  filingId    BigInt   @unique @map("filing_id")
  sourceUrl   String   @map("source_url")
  rawText     String   @map("raw_text")
  rawTextHash String   @map("raw_text_hash")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  filing      Filing   @relation(fields: [filingId], references: [id])

  @@map("filing_documents")
}

model FilingEvent {
  id            BigInt   @id @default(autoincrement())
  filingId      BigInt   @map("filing_id")
  eventType     String   @map("event_type")
  title         String
  summary       String
  amount        String?
  securities    String?
  status        String?
  confidence    String
  sourceSnippet String   @map("source_snippet")
  createdAt     DateTime @default(now()) @map("created_at")
  filing        Filing   @relation(fields: [filingId], references: [id])

  @@index([filingId])
  @@index([eventType])
  @@map("filing_events")
}

