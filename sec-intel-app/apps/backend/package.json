{
  "name": "@sec-intel-app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "seed:tickers": "tsx src/scripts/refreshTickerCache.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@sec-intel-app/shared": "0.1.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "html-to-text": "^9.0.5",
    "openai": "^4.100.0",
    "pg": "^8.14.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "vitest": "^3.1.2"
  }
}

